# ─────────────────────────────────────────────────────────────────────────────
# Rain One Marketing Tools — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev; set the same values in the Vercel project.
# Use the SAME values as the Install Planner / SPIFF Dashboard.

# ─── Supabase (database + auth) — SAME project as SPIFF/Install Planner ───────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# ─── ServiceTitan API (read-only) — SAME credentials as Install Planner ───────
SERVICETITAN_TENANT_ID=2241485589
SERVICETITAN_APP_KEY=your-app-key-from-st-admin
SERVICETITAN_CLIENT_ID=your-client-id
SERVICETITAN_CLIENT_SECRET=your-client-secret
SERVICETITAN_AUTH_URL=https://auth.servicetitan.io/connect/token
SERVICETITAN_API_BASE=https://api.servicetitan.io
